# Azure Speech Service Configuration
# Copy this file to .env and fill in your actual values

# Your Azure Speech Service subscription key
AZURE_SPEECH_KEY=your_subscription_key_here

# Your Azure Speech Service region (e.g., eastus, westus2, southeastasia)
AZURE_SPEECH_REGION=your_region_here

# Your Azure Speech Service endpoint (optional, will be constructed from region if not provided)
AZURE_SPEECH_ENDPOINT=https://your_region.api.cognitive.microsoft.com/